#!/usr/bin/env just --justfile

set fallback

# Run a localhost root relay server with authentication.
root: auth-key
	moq-relay root.toml

# Generate a random secret key for authentication.
auth-key:
	@if [ ! -f "root.jwk" ]; then \
		rm -f *.jwt; \
		moq-token-cli generate --out "root.jwk"; \
	fi

# Generate authentication tokens for local development.
auth-token: auth-key
	@if [ ! -f "root.jwt" ]; then \
		moq-token-cli sign \
			--key "root.jwk" \
			--root "" \
			--subscribe "" \
			--publish "" \
			> root.jwt ; \
	fi
