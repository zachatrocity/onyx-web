#!/bin/bash
set -euo pipefail

# Load .env file if it exists
load_env() {
    if [[ -f ".env" ]]; then
        echo "Loading environment from .env file..."
        set -a  # automatically export all variables
        source .env
        set +a
    elif [[ -f "../.env" ]]; then
        echo "Loading environment from parent .env file..."
        set -a  # automatically export all variables
        source ../.env
        set +a
    fi
}

# Colors for output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Function to check if command exists
command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# Set up environment for dev work
setup_env() {
    # Load environment variables from .env file
    load_env

    print_info "Setting up environment for dev work..."

    # Check prerequisites
    if ! command_exists tofu; then
        print_error "OpenTofu (tofu) not found."
        exit 1
    fi

    # Use TF_CMD from environment if set, otherwise prefer OpenTofu if available
    if [[ -n "${TF_CMD:-}" ]]; then
        if ! command_exists "$TF_CMD"; then
            print_error "Specified TF_CMD '$TF_CMD' not found"
            exit 1
        fi
    elif command_exists tofu; then
        TF_CMD="tofu"
    fi

    # Check if CLOUDFLARE_API_TOKEN is set
    if [[ -z "${CLOUDFLARE_API_TOKEN:-}" ]]; then
        print_error "CLOUDFLARE_API_TOKEN is not set."
        print_error "Set it with: export CLOUDFLARE_API_TOKEN='your-management-token'"
        exit 1
    fi

    # Execute terraform/tofu command in dev environment
    print_info "Running: $TF_CMD $*"
    $TF_CMD "$@"
}

# Show help
show_help() {
    echo "Usage: $0 <terraform-command> [arguments...]"
    echo ""
    echo "Helper script to run Terraform/OpenTofu commands with R2 backend"
    echo ""
    echo "Examples:"
    echo "  $0 plan                 # Run terraform plan"
    echo "  $0 apply                # Run terraform apply"
    echo "  $0 destroy              # Run terraform destroy"
    echo "  $0 init                 # Reinitialize"
    echo "  $0 state list           # List state resources"
    echo ""
    echo "Prerequisites:"
    echo "  - CLOUDFLARE_API_TOKEN must be set"
    echo "  - R2 backend must be set up (run setup-r2-backend.sh first)"
    echo ""
    echo "Environment variables can be set via:"
    echo "  - Environment variables (export CLOUDFLARE_API_TOKEN=...)"
    echo "  - .env file (copy env.example to .env and edit)"
}

# Main execution
if [[ $# -eq 0 ]] || [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
    show_help
    exit 0
fi

setup_env "$@"
