# syntax=docker/dockerfile:1

FROM oven/bun:1.3.14-alpine AS build

WORKDIR /workspace

RUN apk add --no-cache python3 make g++

COPY package.json bun.lock tsconfig.json ./
COPY api/package.json api/tsconfig.json ./api/
COPY app/package.json app/tsconfig.json app/vite.config.ts app/index.html app/index.css app/tailwind.config.js ./app/

RUN bun install --frozen-lockfile

COPY api ./api
COPY app ./app

ENV NODE_ENV=production
ENV VITE_API_URL=/api
ENV VITE_APP_URL=/

RUN bun run --filter='@hang/live' build

FROM nginxinc/nginx-unprivileged:1.27-alpine

COPY docker/nginx-web.conf /etc/nginx/conf.d/default.conf
COPY --chmod=755 docker/web-entrypoint.sh /docker-entrypoint.d/10-onyx-config.sh
COPY --from=build --chown=101:101 /workspace/app/dist /usr/share/nginx/html

USER 101
EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
	CMD wget -qO- http://127.0.0.1:8080/ >/dev/null || exit 1
