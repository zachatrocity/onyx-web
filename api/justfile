#!/usr/bin/env just --justfile

# Using Just: https://github.com/casey/just?tab=readme-ov-file#installation

# List all of the available commands.
default:
  just --list

dev:
	bun wrangler types
	bun wrangler d1 migrations apply DB --local
	bun wrangler dev --var "RELAY_SECRET:$(cat ../moq/rs/dev/root.jwk)"

build:
	bun wrangler types
	bun run build

check:
	bun exec biome check
	bun tsc --noEmit
	#bun exec madge --circular --extensions ts,tsx src

deploy env="staging": build
	bun wrangler d1 migrations apply DB --env "{{env}}" --remote
	bun wrangler deploy --env "{{env}}"
