#!/bin/bash

# Wrapper script to ensure we use the macOS system base64
# which supports BSD-style options that Tauri expects

if [[ "$OSTYPE" == "darwin"* ]]; then
    # On macOS, use the system base64
    exec /usr/bin/base64 "$@"
else
    # On other systems, fall back to whatever base64 is in PATH
    # (excluding this script's directory)
    PATH_WITHOUT_BIN=$(echo "$PATH" | tr ':' '\n' | grep -v "$(dirname "$0")" | tr '\n' ':')
    exec env PATH="$PATH_WITHOUT_BIN" base64 "$@"
fi
