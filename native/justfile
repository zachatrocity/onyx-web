#!/usr/bin/env just --justfile

# Using Just: https://github.com/casey/just?tab=readme-ov-file#installation

# List all of the available commands.
default:
  just --list

# Run the CI checks
check:
	cargo check
	cargo clippy -- -D warnings
	cargo fmt -- --check

# Automatically fix some issues
fix:
	cargo fmt
	cargo clippy --fix --allow-dirty --allow-staged

# Build and upload the app for the given platform
# NOTE: Actually deploying requires extra steps based on the platform
release platform:
	op run --env-file=".env" -- bash ./bin/release-{{platform}}

# Run the native app in development mode
dev:
	cargo tauri dev

android *args:
	cargo tauri android dev --host {{args}}

ios *args:
	cargo tauri ios dev --host {{args}}

# Generate Tauri icons from browser-generated ZIP files
# Prerequisites: Download all ZIP files from http://localhost:1420/dev/icons to this directory
icons:
	@echo "Generating Tauri icons from ZIP files..."
	@rm -rf icons

	# Extract desktop icons directly to final location
	@echo "Extracting desktop icons..."
	@mkdir -p icons
	cd icons && unzip -q ../icons-default.zip

	# Generate Windows ICO file
	@echo "Generating Windows ICO..."
	cd icons && magick 16x16.png 24x24.png 32x32.png 48x48.png 64x64.png 256x256.png 512x512.png icon.ico
	@mv icons/512x512.png icons/icon.png

	# Extract macOS icons directly to final location
	@mkdir -p icons/macos
	@echo "Extracting macOS icons..."
	cd icons/macos && unzip -q ../../icons-macos.zip
	@echo "Generating macOS ICNS with png2icns..."; \
	cd icons/macos && png2icns icon.icns 16x16.png 32x32.png 64x64.png 128x128.png 256x256.png 512x512.png 1024x1024.png; \

	# Extract and organize Android icons to gen/android folders
	@echo "Extracting Android icons..."
	@unzip -o -q icons-android-launcher.zip -d gen/android/app/src/main/res
	@unzip -o -q icons-android-foreground.zip -d gen/android/app/src/main/res
	@unzip -o -q icons-android-background.zip -d gen/android/app/src/main/res
	@unzip -o -q icons-android-round.zip -d gen/android/app/src/main/res

	# Extract iOS icons to gen/apple folders
	@echo "Extracting iOS icons..."
	@unzip -o -q icons-ios.zip -d gen/apple/Assets.xcassets/AppIcon.appiconset

	@echo "✅ Icon generation complete!"
