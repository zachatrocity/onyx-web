#!/usr/bin/env just --justfile

# Using Just: https://github.com/casey/just?tab=readme-ov-file#installation

# List all of the available commands.
default:
  just --list

# Run the CI checks
check:
	cargo check
	cargo clippy -- -D warnings
	cargo fmt -- --check

# Automatically fix some issues
fix:
	cargo fmt
	cargo clippy --fix --allow-dirty --allow-staged

# Build the native app
build:
	cargo tauri build

# Run the native app in development mode
dev:
	cargo tauri dev

# Install dependencies
install:
	cargo fetch

icon:
	cargo tauri icon --ios-color "#000" ../app/public/image/icon.png
	# Mac icons need ~20% transparent padding, so we generate a second set of icons
	cargo tauri icon --output icons/macos ../app/public/image/icon-macos.png
