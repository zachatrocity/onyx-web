{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "hang",
	"version": "0.1.0",
	"identifier": "live.hang.app",
	"build": {
		"devUrl": "http://localhost:1420",
		"beforeDevCommand": "just native-app",
		"beforeBuildCommand": "just build",
		"frontendDist": "../app/dist"
	},
	"app": {
		"windows": [
			{
				"title": "hang.live",
				"width": 1280,
				"height": 720,
				"resizable": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": ["icons/32x32.png", "icons/128x128.png", "icons/256x256.png", "icons/icon.png", "icons/icon.ico"]
	}
}
