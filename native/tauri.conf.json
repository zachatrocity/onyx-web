{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "hang",
	"identifier": "live.hang",
	"version": "0.0.6",
	"build": {
		"devUrl": "http://localhost:1420",
		"beforeDevCommand": {
			"cwd": "..",
			"script": "just dev",
			"wait": false
		},
		"beforeBuildCommand": {
			"cwd": "../app",
			"script": "just build live",
			"wait": true
		},
		"frontendDist": "../app/dist"
	},
	"app": {
		"windows": [
			{
				"title": "hang",
				"width": 1280,
				"height": 720,
				"resizable": true
			}
		],
		"security": {
			"capabilities": ["default"],
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"createUpdaterArtifacts": true,
		"icon": ["icons/32x32.png", "icons/128x128.png", "icons/256x256.png", "icons/icon.png", "icons/icon.ico"],
		"category": "SocialNetworking"
	},
	"plugins": {
		"updater": {
			"endpoints": ["https://hang.live/version/{{target}}/{{arch}}.json"],
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM0NkJCNkJEOEYyNTNBRjIKUldUeU9pV1B2YlpyeEd0MXpyWi8waXdIaExWa1VUblBnamNvWmkxNGZtMk15ZGJSU1REYWFFeWwK"
		},
		"deep-link": {
			"mobile": [{ "host": "hang.live", "pathPrefix": ["/open"] }],
			"desktop": { "schemes": ["hang"] }
		}
	}
}
