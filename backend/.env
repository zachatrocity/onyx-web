# Listen for connections on this address.
API_BIND = "0.0.0.0:3000"

# The URL of the API server
API_URL = "http://localhost:3000/"

# A secret used to sign auth tokens.
API_SECRET = "your-super-secret-jwt-key-here"

# The URL of the frontend server.
FRONTEND_URL = "http://localhost:1420/"

# Use a local postgress instance.
# NOTE: This is used by sqlx to validate schemas.
DATABASE_URL="postgres:///hang?host=/tmp"

# Default to saving offline schemas
# You can temporarily set this to `false` to validate live, at the cost of slower compile times.
SQLX_OFFLINE="false"

STORAGE_TYPE = "disk"
STORAGE_BUCKET = "./uploads"

