# Database
DATABASE_URL=postgresql://hang_user:hang_password@localhost:5432/hang_db

# JWT Secret (generate a random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Base URL for OAuth redirects
BASE_URL=http://localhost:3001

# Storage configuration
# Options: local, s3, gcs
STORAGE_TYPE=local

# Local storage (when STORAGE_TYPE=local)
STORAGE_LOCAL_PATH=./uploads

# S3 storage (when STORAGE_TYPE=s3)
STORAGE_S3_BUCKET=hang-avatars
STORAGE_S3_REGION=us-east-1
# For local development with MinIO
# STORAGE_S3_ENDPOINT=http://localhost:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin

# GCS storage (when STORAGE_TYPE=gcs)
# STORAGE_GCS_BUCKET=hang-avatars
# STORAGE_GCS_PROJECT_ID=your-project-id

# Server port
PORT=3001

# Log level
RUST_LOG=hang_api=debug,tower_http=debug
